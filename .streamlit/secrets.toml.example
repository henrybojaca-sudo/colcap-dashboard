# Renombra este archivo a secrets.toml y completa tus credenciales SMTP.
# En Streamlit Cloud, configura estos valores en Settings → Secrets.

[smtp]
sender   = "tu_correo@gmail.com"      # correo remitente
password = "xxxx xxxx xxxx xxxx"      # contraseña de aplicación (Gmail App Password)
host     = "smtp.gmail.com"           # servidor SMTP (por defecto Gmail)
port     = 587                        # puerto STARTTLS
